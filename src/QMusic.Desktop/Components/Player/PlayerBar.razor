@implements IDisposable
@inject MusicPlayerService Player
@inject IJSRuntime JS

<div class="player-bar">
    <div class="player-single-row">
        <div class="player-track-info">
            @if (Player.CurrentTrack is { } track)
            {
                <div class="player-album-art">
                    @if (!string.IsNullOrEmpty(track.AlbumArtUrl))
                    {
                        <img src="@track.AlbumArtUrl" alt="@track.Title" />
                    }
                    else
                    {
                        <span>&#9835;</span>
                    }
                </div>
                <div class="player-track-text">
                    <div class="track-title @(IsOverflow(track.Title) ? "marquee-scroll" : "")"
                         @onclick="() => CopyToClipboard(track.Title)" title="Click to copy" style="cursor: pointer;">
                        <span class="marquee-text">@(IsOverflow(track.Title) ? $"{track.Title}       {track.Title}" : track.Title)</span>
                    </div>
                    <div class="track-artist @(IsOverflow(track.Artist) ? "marquee-scroll" : "")">
                        <span class="marquee-text">@(IsOverflow(track.Artist) ? $"{track.Artist}       {track.Artist}" : track.Artist)</span>
                    </div>
                </div>
            }
            else
            {
                <div class="player-album-art">&#9835;</div>
                <div class="player-track-text">
                    <div class="track-title" style="color: var(--text-muted);">Not playing</div>
                </div>
            }
        </div>

        <div class="player-center">
            <div class="player-buttons">
                <button class="player-btn player-btn-sm" title="Previous">&#9664;&#9664;</button>
                <button class="player-btn play-btn play-btn-sm" @onclick="TogglePlayPause" title="Play/Pause">
                    @if (Player.State == PlaybackState.Playing)
                    {
                        <span>&#10074;&#10074;</span>
                    }
                    else
                    {
                        <span>&#9654;</span>
                    }
                </button>
                <button class="player-btn player-btn-sm" title="Next">&#9654;&#9654;</button>
            </div>

            <div class="player-progress">
                <span class="progress-time">@FormatTime(Player.CurrentPosition)</span>
                <div class="progress-bar-container">
                    <div class="progress-bar-track">
                        <div class="progress-bar-fill" style="width: @ProgressPercent%;"></div>
                    </div>
                    <input type="range"
                           class="progress-bar-input"
                           min="0"
                           max="@((int)Player.TotalDuration.TotalSeconds)"
                           value="@((int)Player.CurrentPosition.TotalSeconds)"
                           @oninput="OnSeek" />
                </div>
                <span class="progress-time">@FormatTime(Player.TotalDuration)</span>
            </div>
        </div>

        <div class="player-volume">
            <div class="volume-control">
                <input type="range"
                       class="volume-slider"
                       min="0"
                       max="100"
                       value="@Player.Volume"
                       @oninput="OnVolumeChange" />
                <button class="player-btn volume-btn" @onclick="ToggleMute" title="Volume">
                    @VolumeIcon
                </button>
                <span class="volume-label">@Player.Volume</span>
            </div>
        </div>
    </div>
</div>

@code {
    private int _volumeBeforeMute;
    private bool _isMuted;

    private string ProgressPercent =>
        Player.TotalDuration.TotalSeconds > 0
            ? ((Player.CurrentPosition.TotalSeconds / Player.TotalDuration.TotalSeconds) * 100)
                .ToString("F1", System.Globalization.CultureInfo.InvariantCulture)
            : "0";

    protected override void OnInitialized()
    {
        Player.StateChanged += OnStateChanged;
        Player.PositionChanged += OnPositionChanged;
    }

    private async void OnStateChanged(object? sender, PlaybackState state)
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnPositionChanged(object? sender, TimeSpan position)
    {
        await InvokeAsync(StateHasChanged);
    }

    private void TogglePlayPause()
    {
        if (Player.State == PlaybackState.Playing)
            Player.Pause();
        else
            Player.Resume();
    }

    private void OnSeek(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var seconds))
        {
            Player.Seek(TimeSpan.FromSeconds(seconds));
        }
    }

    private void OnVolumeChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var volume))
        {
            Player.Volume = volume;
            _isMuted = volume == 0;
        }
    }

    private void ToggleMute()
    {
        if (_isMuted)
        {
            Player.Volume = _volumeBeforeMute > 0 ? _volumeBeforeMute : 50;
            _isMuted = false;
        }
        else
        {
            _volumeBeforeMute = Player.Volume;
            Player.Volume = 0;
            _isMuted = true;
        }
    }

    private string VolumeIcon => Player.Volume switch
    {
        0 => "\U0001F507",      // muted
        <= 33 => "\U0001F508",  // low
        <= 66 => "\U0001F509",  // medium
        _ => "\U0001F50A"       // high
    };

    private async Task CopyToClipboard(string? text)
    {
        if (!string.IsNullOrEmpty(text))
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private const int MarqueeThreshold = 30;

    private static bool IsOverflow(string? text) =>
        text is not null && text.Length > MarqueeThreshold;

    private static string FormatTime(TimeSpan time) =>
        time.TotalHours >= 1
            ? time.ToString(@"h\:mm\:ss")
            : time.ToString(@"m\:ss");

    public void Dispose()
    {
        Player.StateChanged -= OnStateChanged;
        Player.PositionChanged -= OnPositionChanged;
    }
}
