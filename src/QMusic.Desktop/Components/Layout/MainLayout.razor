@inherits LayoutComponentBase
@implements IDisposable
@inject SourceManagerService SourceManager
@inject MusicPlayerService Player
@inject IAuthenticationService Auth

<div class="app-layout @ThemeClass">
    <header class="top-bar">
        <div class="top-bar-left">
            <span class="top-bar-brand">Q-Music</span>
        </div>
        <div class="top-bar-center">
            <input class="top-bar-search"
                   type="text"
                   placeholder="Search for music..."
                   @bind="_query"
                   @bind:event="oninput"
                   @onkeydown="HandleSearchKeyDown" />
        </div>
        <div class="top-bar-right">
            <div class="top-bar-profile" @onclick="HandleProfileClick" title="@(_isAuthenticated ? _userProfile?.DisplayName ?? "Profile" : "Sign in")">
                @if (_isAuthenticated && _userProfile?.ProfilePictureUrl is not null)
                {
                    <img src="@_userProfile.ProfilePictureUrl" alt="Profile" class="profile-avatar" />
                }
                else
                {
                    <span>&#128100;</span>
                }
            </div>
            @if (_isAuthenticated)
            {
                <div class="top-bar-icon" @onclick="HandleLogout" title="Sign out">
                    &#x23FB;
                </div>
            }
            <div class="top-bar-icon" title="Settings">
                &#9881;
            </div>
        </div>
    </header>

    <nav class="sidebar">
        <div class="sidebar-section">Sources</div>
        <SourceSelector />

        <div class="sidebar-section">Library</div>
        <div class="sidebar-item @(_activeView == "Search" ? "active" : "")" @onclick="ShowSearch">Search</div>

        @if (_isAuthenticated && _playlists.Count > 0)
        {
            <div class="sidebar-divider"></div>
            <div class="sidebar-section">Your Playlists</div>
            <div class="sidebar-playlists">
                @foreach (var playlist in _playlists)
                {
                    <div class="sidebar-item sidebar-playlist-item @(_activeView == "Playlist" && _selectedPlaylistId == playlist.Id ? "active" : "")"
                         @onclick="() => SelectPlaylist(playlist.Id)" title="@playlist.Title">
                        <span class="playlist-name">@playlist.Title</span>
                        <span class="playlist-count">@playlist.TrackCount</span>
                    </div>
                }
            </div>
        }
        else if (_isAuthenticated && _loadingPlaylists)
        {
            <div class="sidebar-divider"></div>
            <div class="sidebar-section">Your Playlists</div>
            <div class="sidebar-item" style="color: var(--text-muted); font-size: 0.8rem;">Loading...</div>
        }
    </nav>

    <main class="content">
        <CascadingValue Value="_displayTracks" Name="DisplayTracks">
            <CascadingValue Value="_hasContent" Name="HasContent">
                @Body
            </CascadingValue>
        </CascadingValue>
    </main>

    <PlayerBar />
</div>

@code {
    private string _query = string.Empty;
    private List<TrackDto> _searchResults = [];
    private bool _hasSearched;
    private bool _isAuthenticated;
    private UserProfile? _userProfile;
    private List<PlaylistDto> _playlists = [];
    private string? _selectedPlaylistId;
    private List<TrackDto> _playlistTracks = [];
    private bool _loadingPlaylists;
    private string _activeView = "Search";

    // Unified track list for the content area
    private List<TrackDto> _displayTracks => _activeView == "Playlist" ? _playlistTracks : _searchResults;
    private bool _hasContent => _activeView == "Playlist" ? _playlistTracks.Count > 0 || _selectedPlaylistId is not null : _hasSearched;

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_query))
        {
            _activeView = "Search";
            _searchResults = (await Player.SearchAsync(_query)).ToList();
            _hasSearched = true;
        }
    }

    private void ShowSearch()
    {
        _activeView = "Search";
    }

    private async Task SelectPlaylist(string playlistId)
    {
        _selectedPlaylistId = playlistId;
        _activeView = "Playlist";
        _playlistTracks = (await Player.GetPlaylistTracksAsync(playlistId)).ToList();
    }

    private async Task HandleProfileClick()
    {
        if (!_isAuthenticated)
        {
            await Auth.LoginAsync();
            await LoadProfileAsync();
        }
    }

    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        _isAuthenticated = false;
        _userProfile = null;
        _playlists = [];
        _playlistTracks = [];
        _selectedPlaylistId = null;
        _activeView = "Search";
    }

    private async Task LoadProfileAsync()
    {
        _isAuthenticated = await Auth.IsAuthenticatedAsync();
        if (_isAuthenticated)
        {
            _userProfile = await Auth.GetUserProfileAsync();
            await LoadPlaylistsAsync();
        }
    }

    private async Task LoadPlaylistsAsync()
    {
        _loadingPlaylists = true;
        StateHasChanged();
        _playlists = (await Player.GetUserPlaylistsAsync()).ToList();
        _loadingPlaylists = false;
    }

    private string ThemeClass => SourceManager.ActiveSource switch
    {
        MusicSource.YouTubeMusic => "theme-youtube",
        MusicSource.Spotify => "theme-spotify",
        _ => "theme-youtube"
    };

    protected override async Task OnInitializedAsync()
    {
        SourceManager.ActiveSourceChanged += OnSourceChanged;
        Auth.AuthenticationStateChanged += OnAuthStateChanged;
        await LoadProfileAsync();
    }

    private async void OnSourceChanged(MusicSource _)
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthStateChanged(bool isAuthenticated)
    {
        await InvokeAsync(async () =>
        {
            await LoadProfileAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SourceManager.ActiveSourceChanged -= OnSourceChanged;
        Auth.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
