@inject MusicPlayerService Player

<div class="track-card" @onclick="PlayTrack">
    <div class="track-card-art">&#9835;</div>
    <div class="track-card-info">
        <div class="track-card-title">@Track.Title</div>
        <div class="track-card-artist">@Track.Artist</div>
    </div>
    <div class="track-card-duration">@Track.DurationFormatted</div>
</div>

@code {
    [Parameter, EditorRequired]
    public required TrackDto Track { get; set; }

    private async Task PlayTrack()
    {
        // Parse the composite ID back — format is "Source:Value"
        var parts = Track.Id.Split(':', 2);
        if (parts.Length == 2 && Enum.TryParse<MusicSource>(parts[0], out var source))
        {
            var trackId = new QMusic.Domain.ValueObjects.TrackId(source, parts[1]);
            await Player.PlayTrackAsync(trackId);
        }
    }
}
