<Window x:Class="QMusic.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:local="clr-namespace:QMusic.Desktop"
        Title="QMusic"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <!--
        BlazorWebView is the bridge between WPF and Blazor.
        It hosts a WebView2 control that renders our Blazor components.
        HostPage points to the HTML file that loads the Blazor framework.
        The RootComponent tells Blazor which component to render and where (#app selector).
    -->
    <blazor:BlazorWebView x:Name="BlazorWebView" HostPage="wwwroot/index.html">
        <blazor:BlazorWebView.RootComponents>
            <blazor:RootComponent Selector="#app" ComponentType="{x:Type local:Routes}" />
        </blazor:BlazorWebView.RootComponents>
    </blazor:BlazorWebView>
</Window>
